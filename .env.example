# Configuration Supabase
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_KEY=votre_clé_anon_supabase
# Alternative: SUPABASE_ANON_KEY=votre_clé_anon_supabase
# Secret JWT (Project Settings > API > JWT Secret) pour vérifier les tokens en production
SUPABASE_JWT_SECRET=votre_jwt_secret_supabase

# Configuration Stripe
STRIPE_PUBLIC_KEY=pk_test_votre_clé_publique_stripe
STRIPE_SECRET_KEY=sk_test_votre_clé_secrète_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_webhook_stripe

# Configuration Email (Resend)
RESEND_API_KEY=re_votre_clé_api_resend
SENDER_EMAIL=noreply@fitmatch.fr

# Configuration Email alternative (SendGrid - optionnel)
SENDGRID_API_KEY=SG.votre_clé_api_sendgrid

# Configuration Google Maps/Places API
GOOGLE_MAPS_API_KEY=votre_clé_api_google_maps
# Alternative: GOOGLE_PLACES_API_KEY=votre_clé_api_google_places

# Configuration Base de données (REQUIS en production - pas de mode démo)
# Sans DATABASE_URL, les utilisateurs et réservations ne sont pas persistés.
DATABASE_URL=postgresql://user:password@localhost:5432/fitmatch

# Cron rappels (serverless) : secret pour appeler GET /api/reminders/process (query ?secret=... ou header X-Cron-Secret)
# CRON_SECRET=un_secret_long_aleatoire

# CORS (production : liste d'origines séparées par des virgules)
# Ex: CORS_ORIGINS=https://fitmatch.fr,https://www.fitmatch.fr
# Non défini ou * = autoriser toutes les origines
# CORS_ORIGINS=

# Configuration URL du site
SITE_URL=http://localhost:5000
# Pour Replit:
REPLIT_DEV_DOMAIN=votre-domaine.replit.dev
REPLIT_DEPLOYMENT=0
REPLIT_CONNECTORS_HOSTNAME=
REPL_IDENTITY=
WEB_REPL_RENEWAL=

# Configuration JWT (si utilisé séparément)
JWT_SECRET_KEY=votre_clé_secrète_jwt
